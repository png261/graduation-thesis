{
  "name": "deepagents-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint --config eslint.config.mjs \"src/**/*.{ts,tsx}\"",
    "lint:fix": "npm run lint -- --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate:api-types": "cd ../.. && python3 scripts/export_openapi_schema.py --output src/frontend/src/api/generated/openapi-schema.json && cd src/frontend && openapi-typescript src/api/generated/openapi-schema.json -o src/api/generated/openapi-types.ts",
    "format": "cd ../.. && prettier --config .prettierrc.json --ignore-path .prettierignore --write --ignore-unknown \"src/frontend/src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"src/backend/**/*.{json,md,yml,yaml}\" \"README.md\" \"src/backend/README.md\"",
    "format:check": "cd ../.. && prettier --config .prettierrc.json --ignore-path .prettierignore --check --ignore-unknown \"src/frontend/src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"src/backend/**/*.{json,md,yml,yaml}\" \"README.md\" \"src/backend/README.md\"",
    "check:function-length": "python3 ../../scripts/check_function_lengths.py --target frontend --max-lines 500 --strict",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build && npm run check:function-length"
  },
  "dependencies": {
    "@assistant-ui/react": "0.12.5",
    "@assistant-ui/react-ai-sdk": "1.3.0",
    "@assistant-ui/react-ui": "0.2.1",
    "@clerk/clerk-react": "^5.61.3",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.544.0",
    "eventsource-parser": "^3.0.6",
    "react": "^18.2.0",
    "react-complex-tree": "^2.6.1",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^2.1.7",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "jsdom": "^26.1.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.32",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.4.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
